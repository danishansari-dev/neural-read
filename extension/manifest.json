{
    "manifest_version": 3,
    "name": "NeuralRead",
    "version": "1.0.0",
    "description": "Auto-highlights important sentences on webpages and builds a personal knowledge graph.",
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "https://neural-read-dashboard.vercel.app/*",
        "https://neural-read-backend-production.up.railway.app/*"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "config.js",
                "styles.css"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "background": {
        "service_worker": "background.js",
        "type": "classic"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "exclude_matches": [
        "http://localhost/*",
        "https://localhost/*",
        "http://127.0.0.1/*",
        "https://127.0.0.1/*",
        "https://*.vercel.app/*",
        "https://*.supabase.com/*",
        "https://railway.app/*",
        "https://*.railway.app/*",
        "https://github.com/*",
        "https://chrome.google.com/*"
      ],
            "js": [
                "config.js",
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "NeuralRead Config"
    }
}