{
    "manifest_version": 3,
    "name": "NeuralRead",
    "version": "1.0",
    "description": "Auto-highlights important sentences on webpages and builds a personal knowledge graph.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "http://localhost/*",
        "https://neural-read-dashboard-git-main-danishs-projects-25aab0a7.vercel.app/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "exclude_matches": [
                "http://localhost/*",
                "https://localhost/*",
                "http://127.0.0.1/*",
                "https://127.0.0.1/*",
                "https://neural-read-dashboard-git-main-danishs-projects-25aab0a7.vercel.app/*"
            ],
            "js": [
                "config.js",
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "NeuralRead Config"
    }
}